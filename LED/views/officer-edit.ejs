<%- include('partials/shell-top', { pageTitle: 'Edit Officer', active: 'officers' }) %>

<section class="panel">
    <h3 class="mt-0">Edit &mdash; <%= officer.first_name %> <%= officer.last_name %> (#<%= officer.badge_number %>)</h3>

    <form action="/officers/<%= officer.badge_number %>/edit" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-grid">
            <div class="field"><label>First Name</label><input type="text" name="first_name" value="<%= officer.first_name %>" required></div>
            <div class="field"><label>Last Name</label><input type="text" name="last_name" value="<%= officer.last_name %>" required></div>
            <div class="field"><label>Agency Name</label><input type="text" name="agency_name" value="<%= officer.agency_name %>" required></div>
            <div class="field"><label>Work Email</label><input type="email" name="work_email" value="<%= officer.work_email %>" required></div>
            <div class="field"><label>Rank</label><input type="text" name="officer_rank" value="<%= officer.officer_rank || '' %>"></div>
            <div class="field"><label>Unit / Division</label><input type="text" name="unit_division" value="<%= officer.unit_division || '' %>"></div>
            <div class="field">
                <label>Duty Status</label>
                <select name="duty_status">
                    <option value="Active" <%= officer.duty_status === 'Active' ? 'selected' : '' %>>Active</option>
                    <option value="Inactive" <%= officer.duty_status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
                    <option value="Terminated" <%= officer.duty_status === 'Terminated' ? 'selected' : '' %>>Terminated</option>
                </select>
            </div>
            <div class="field">
                <label>Role</label>
                <select name="role">
                    <option value="User" <%= officer.role === 'User' ? 'selected' : '' %>>User</option>
                    <option value="Admin" <%= officer.role === 'Admin' ? 'selected' : '' %>>Admin</option>
                </select>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a class="btn btn-ghost" href="/officers/<%= officer.badge_number %>">Cancel</a>
        </div>
    </form>
</section>

<%- include('partials/shell-bottom') %>
