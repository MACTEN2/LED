<%- include('partials/shell-top', { pageTitle: 'Overview', active: 'dashboard' }) %>

<div class="stat-grid">
    <div class="stat-tile tile-success">
        <div class="value"><%= equipmentCounts.available || 0 %></div>
        <div class="label">Gear Available</div>
    </div>
    <div class="stat-tile tile-warning">
        <div class="value"><%= equipmentCounts.deployed || 0 %></div>
        <div class="label">Gear Deployed</div>
    </div>
    <div class="stat-tile tile-danger">
        <div class="value"><%= equipmentCounts.maintenance || 0 %></div>
        <div class="label">In Maintenance</div>
    </div>
    <div class="stat-tile">
        <div class="value"><%= officerCounts.active || 0 %> / <%= officerCounts.total || 0 %></div>
        <div class="label">Officers On Duty</div>
    </div>
    <div class="stat-tile tile-warning">
        <div class="value"><%= reportCounts.open || 0 %></div>
        <div class="label">Open Reports</div>
    </div>
</div>

<% if (codeRed && codeRed.active) { %>
    <section class="panel emergency-panel">
        <h3>&#9888; Rapid Access &mdash; Code Red</h3>
        <div class="quick-grid">
            <a class="btn btn-danger" href="/equipment">Armory</a>
            <a class="btn btn-danger" href="/officers">Roster</a>
            <a class="btn btn-danger" href="/reports/new">File Report</a>
        </div>
        <div class="form-grid mt-lg">
            <div>
                <h4>On-Duty Officers</h4>
                <% if (onDutyOfficers.length === 0) { %>
                    <p class="empty-state">None on duty.</p>
                <% } else { %>
                    <ul>
                        <% onDutyOfficers.forEach(o => { %>
                            <li><a href="/officers/<%= o.badge_number %>"><%= o.first_name %> <%= o.last_name %></a> &mdash; <%= o.unit_division || 'Unassigned' %></li>
                        <% }); %>
                    </ul>
                <% } %>
            </div>
            <div>
                <h4>Available Gear</h4>
                <% if (availableGear.length === 0) { %>
                    <p class="empty-state">Nothing available.</p>
                <% } else { %>
                    <ul>
                        <% availableGear.forEach(g => { %>
                            <li><%= g.item_name %> <span class="text-muted">(<%= g.asset_tag %>)</span></li>
                        <% }); %>
                    </ul>
                <% } %>
            </div>
        </div>
    </section>
<% } %>

<section class="panel">
    <h3>Recent Activity</h3>
    <% if (logs.length === 0) { %>
        <p class="empty-state">No recent activity.</p>
    <% } else { %>
        <% logs.forEach(log => { %>
            <p><span class="text-muted"><%= new Date(log.timestamp).toLocaleString() %></span> &mdash; <strong><%= log.action_type %></strong>: <%= log.details %></p>
        <% }); %>
    <% } %>
</section>

<%- include('partials/shell-bottom') %>
