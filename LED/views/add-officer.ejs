<!DOCTYPE html>
<html>
<head>
    <title>LED | Add New Officer</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h1>Register New Personnel</h1>
    <form action="/add-officer" method="POST">
        <input type="number" name="badge_number" placeholder="Badge Number" required>
        <input type="text" name="first_name" placeholder="First Name" required>
        <input type="text" name="last_name" placeholder="Last Name" required>
        <input type="text" name="rank" placeholder="Rank (e.g. Special Agent)">
        <input type="text" name="agency" value="Federal Bureau of Investigation">
        <input type="email" name="email" placeholder="Work Email">
        <input type="password" name="password" placeholder="Temporary Access Code" required>
        
        <select name="role">
            <option value="User">User</option>
            <option value="Admin">Admin</option>
        </select>
        
        <button type="submit">Deploy Officer</button>
    </form>
    <a href="/dashboard">Return to Command</a>
</body>
</html>